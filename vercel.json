{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "client/build",
  "functions": {
    "api/[...all].js": {
      "runtime": "nodejs20.x"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/[...all]"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
